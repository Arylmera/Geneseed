{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENT.md"],
  "permission": {
    "bash": {
      "rm -rf *": "ask",
      "git commit*": "ask",
      "git push*": "ask",
      "git push --force*": "ask",
      "git push -f*": "ask"
    }
  },
  "lsp": true,
  "mcp": {
    "markitdown": {
      "type": "local",
      "command": ["uvx", "markitdown-mcp"],
      "enabled": true
    },
    "gitlab": {
      "type": "local",
      "command": ["npx", "-y", "@zereight/mcp-gitlab"],
      "environment": {
        "GITLAB_PERSONAL_ACCESS_TOKEN": "",
        "GITLAB_API_URL": "https://gitlab.com/api/v4"
      },
      "enabled": false
    },
    "gitlab-2": {
      "type": "local",
      "command": ["npx", "-y", "@zereight/mcp-gitlab"],
      "environment": {
        "GITLAB_PERSONAL_ACCESS_TOKEN": "",
        "GITLAB_API_URL": "https://gitlab.example.com/api/v4"
      },
      "enabled": false
    },
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "/path/to/allowed/dir"],
      "enabled": false
    }
  }
}
