{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          { "type": "command", "command": "cat AGENT.md" },
          { "type": "command", "command": "python rituals/harness.py context" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "python rituals/harness.py learn < /dev/null || true" }
        ]
      }
    ]
  }
}
