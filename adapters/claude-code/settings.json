{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "python rituals/harness.py git-gate" }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|clear",
        "hooks": [
          { "type": "command", "command": "cat AGENT.md" },
          { "type": "command", "command": "python rituals/harness.py context" }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          { "type": "command", "command": "python rituals/harness.py context" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "python rituals/harness.py learn || true" }
        ]
      }
    ]
  }
}
