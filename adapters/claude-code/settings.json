{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "python rituals/harness.py git-gate" }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|clear",
        "hooks": [
          { "type": "command", "command": "python -c \"import sys;sys.stdout.write(open('AGENT.md',encoding='utf-8').read())\"" },
          { "type": "command", "command": "python rituals/harness.py context" }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          { "type": "command", "command": "python rituals/harness.py context" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "python rituals/harness.py learn || exit 0" }
        ]
      }
    ]
  }
}
