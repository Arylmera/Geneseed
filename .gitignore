__pycache__/
*.pyc
.geneseed-mirror/
*.log

# Generated build output — derivable from src/ via build.py, never committed.
Harness/
# Exported deployed-vs-source improvements reports (geneseed diff --out). Auto-exports
# land inside the deployed harness dir, but a hand-aimed --out here stays personal.
improvements/
# Host-specific project-context manifest, if a build drops one at the repo root.
/context.json
# Agent Notebook — personal/agent scratch space, never committed (AGENT.md §5).
notebook/

# Brainstorming visual companion (transient)
.superpowers/

# Web UI: dev-only deps (dist/ is committed and MUST stay tracked)
web/node_modules/
# Stray vite cache when a build is invoked from the repo root instead of web/
/node_modules/

# Local working docs — dated specs, reviews, and superpowers plans are per-machine
# work artifacts (drafted, executed, then dropped), never distributed with the repo.
docs/specs/
docs/reviews/
docs/superpowers/

# macOS Finder metadata
.DS_Store
