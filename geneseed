#!/usr/bin/env bash
#
# Geneseed — front door. One launcher for everything.
#
#     ./geneseed                          open the interactive main menu (pick any action)
#     ./geneseed tui                      open the control panel (browse)
#     ./geneseed setup                    guided, dependency-free install wizard
#     ./geneseed bootstrap [ref] [theme]  update everything, then run setup
#     ./geneseed update    [ref] [theme]  update everything (sync + upgrade), no setup
#     ./geneseed build [args]             render the bundle
#     ./geneseed doctor [args]            validate (themes, parity, authoring, drift)
#     ./geneseed diff [args]              compare a deployed harness against source
#     ./geneseed context|learn|prompt [args]
#     ./geneseed upgrade [ref] [theme]    self-upgrade from the published source
#     ./geneseed sync-self [ref]          refresh the launcher + upgrade scripts
#     ./geneseed link [dir]               put `geneseed` on PATH (run it from anywhere)
#     ./geneseed unlink                   remove the on-PATH launcher symlink
#     ./geneseed help
#
# Bare `./geneseed` opens an interactive main menu listing every action (update,
# setup, browse, doctor, build, diff …) — just run it and pick. Thin wrapper over
# `python3 rituals/harness.py <cmd>` (+ the scripts); no deps. On Windows, use the
# native launchers `geneseed.cmd` / `geneseed.ps1` (same subcommands, no bash).
#
# `bootstrap`/`update` exec into the bootstrap script so this launcher is replaced
# before sync-self rewrites it on disk.

set -eo pipefail
# Resolve through symlinks so the launcher works when invoked via a symlink on
# PATH (see `geneseed link`): HERE must be the real repo dir, not the link's dir,
# or rituals/harness.py and the sibling scripts would not be found.
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  dir="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  case "$SOURCE" in /*) ;; *) SOURCE="$dir/$SOURCE" ;; esac
done
HERE="$(cd -P "$(dirname "$SOURCE")" && pwd)"
# Pick the first interpreter that actually RUNS — on Windows Git Bash, `python3`
# resolves to the Microsoft Store alias stub, which exists on PATH but only prints
# an install hint and exits non-zero. $PYTHON still overrides everything.
PY="${PYTHON:-}"
if [ -z "$PY" ]; then
  for c in python3 python py; do
    if command -v "$c" >/dev/null 2>&1 && "$c" -c 'pass' >/dev/null 2>&1; then PY="$c"; break; fi
  done
  PY="${PY:-python3}"
fi

# Bare `./geneseed` opens the interactive main menu.
if [ "$#" -eq 0 ]; then set -- menu; fi
cmd="$1"
case "$cmd" in
  menu|tui|setup|build|doctor|diff|context|learn|prompt|version|status|uninstall|upgrade|sync-self|link|unlink)
    # All of these are implemented in the cross-platform Python CLI (single source of
    # truth) — upgrade/sync-self/link/unlink were ported out of bash so they run on
    # native Windows too (see rituals/_update.py and cmd_link/cmd_unlink in harness.py).
    exec "$PY" "$HERE/rituals/harness.py" "$@"
    ;;
  bootstrap)
    shift || true; exec "$HERE/bootstrap" "$@"
    ;;
  update)
    shift || true; exec "$HERE/bootstrap" --no-setup "$@"
    ;;
  -h|--help|help)
    cat <<'USAGE'
geneseed — front door for the Geneseed harness

  ./geneseed                          open the interactive main menu (pick any action)
  ./geneseed tui                      open the control panel (browse)
  ./geneseed setup                    guided install wizard
  ./geneseed bootstrap [ref] [theme]  update everything, then run setup
  ./geneseed update    [ref] [theme]  update everything (sync + upgrade)
  ./geneseed build|doctor|diff|context|learn|prompt [args]
  ./geneseed version                  installed vs current-source fingerprint
  ./geneseed status                   install dashboard as text (theme/mode/counts)
  ./geneseed uninstall [--yes]        remove a global install (keeps memory)
  ./geneseed upgrade [ref] [theme]    self-upgrade from the published source
  ./geneseed sync-self [ref]          refresh the launcher + upgrade scripts
  ./geneseed link [dir]               put `geneseed` on PATH so it runs from any directory
                                      (default ~/.local/bin; pass a dir to override)
  ./geneseed unlink                   remove the on-PATH launcher symlink

Once linked and on PATH, drop the leading `./` — just `geneseed`, `geneseed build`, etc.
USAGE
    ;;
  *)
    echo "geneseed: unknown command '$cmd' — try: ./geneseed help" >&2
    exit 2
    ;;
esac
